---
import RevealSection from '../islands/RevealSection';
---

<section id="contact" class="px-4 py-24 border-t border-border">
  <RevealSection client:visible>
  <div class="mx-auto max-w-4xl">
    <h2 class="font-mono text-[10px] text-fg-muted uppercase tracking-widest mb-12">
      ~/contact
    </h2>

    <div class="max-w-lg">
      <p class="text-fg-secondary mb-10 leading-relaxed">
        Available for senior / staff backend or platform engineering roles and
        contracts. Best reached by email — no form, no scheduling link.
      </p>

      <div class="space-y-4 font-mono text-sm">
        <a
          href="mailto:mokaysteve@gmail.com"
          class="flex items-center gap-3 text-fg hover:text-accent transition-colors duration-150 group"
        >
          <span class="text-fg-muted group-hover:text-accent transition-colors duration-150 w-4">@</span>
          mokaysteve@gmail.com
        </a>
        <a
          href="https://github.com/mokaysteve"
          class="flex items-center gap-3 text-fg hover:text-accent transition-colors duration-150 group"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="text-fg-muted group-hover:text-accent transition-colors duration-150 w-4">⌥</span>
          github.com/mokaysteve
        </a>
      </div>
    </div>
  </div>
  </RevealSection>
</section>
