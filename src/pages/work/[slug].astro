---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const studies = await getCollection('case-studies');
  return studies.map((study) => ({
    params: { slug: study.slug },
    props: { study },
  }));
}

const { study } = Astro.props;
const { Content } = await study.render();
---

<Base title={`${study.data.title} — Case Study`} description={study.data.summary}>
  <article class="px-4 py-24 mx-auto max-w-3xl">
    <nav class="font-mono text-xs text-fg-muted mb-12" aria-label="Breadcrumb">
      <a href="/" class="hover:text-accent transition-colors duration-150">~/</a>
      <span class="mx-1.5 text-fg-muted/40">›</span>
      <a href="/#work" class="hover:text-accent transition-colors duration-150">work</a>
      <span class="mx-1.5 text-fg-muted/40">›</span>
      <span class="text-fg-secondary">{study.slug}</span>
    </nav>

    <header class="mb-12">
      {study.data.draft && (
        <div class="font-mono text-xs text-warn border border-warn/30 px-3 py-1.5 mb-6 inline-block">
          draft — not published
        </div>
      )}

      <h1 class="font-mono text-xl text-accent mb-4 leading-tight" transition:name={`cs-title-${study.slug}`}>
        {study.data.title}
      </h1>
      <p class="text-fg-secondary leading-relaxed mb-6 max-w-xl">
        {study.data.summary}
      </p>

      <div class="flex flex-wrap gap-2 mb-8">
        {study.data.tags.map((tag) => (
          <span class="font-mono text-[10px] border border-border px-2 py-0.5 text-fg-muted">
            {tag}
          </span>
        ))}
      </div>

      <div class="border border-border bg-surface grid sm:grid-cols-3 gap-4 p-4 font-mono text-xs">
        {[
          { label: 'before', value: study.data.metrics.before, color: 'text-fg' },
          { label: 'after', value: study.data.metrics.after, color: 'text-fg' },
          { label: 'improvement', value: study.data.metrics.improvement, color: 'text-ok' },
        ].map(({ label, value, color }) => (
          <div>
            <div class="text-fg-muted text-[10px] uppercase tracking-widest mb-1">{label}</div>
            <div class:list={[color]}>{value}</div>
          </div>
        ))}
      </div>
    </header>

    <div class="prose prose-invert prose-sm max-w-none
      prose-headings:font-mono prose-headings:text-accent prose-headings:font-normal prose-headings:tracking-tight
      prose-p:text-fg-secondary prose-p:leading-relaxed
      prose-a:text-accent prose-a:no-underline hover:prose-a:underline
      prose-code:text-accent prose-code:bg-surface prose-code:px-1 prose-code:py-0.5 prose-code:text-[0.85em] prose-code:before:content-none prose-code:after:content-none
      prose-pre:bg-surface prose-pre:border prose-pre:border-border prose-pre:rounded-none
      prose-strong:text-fg
      prose-table:font-mono prose-table:text-xs
      prose-th:text-fg-muted prose-th:font-normal prose-th:border-b prose-th:border-border prose-th:py-2
      prose-td:border-b prose-td:border-border/50 prose-td:text-fg-secondary prose-td:py-2
      prose-blockquote:border-l-accent prose-blockquote:text-fg-secondary
      prose-hr:border-border
    ">
      <Content />
    </div>

    <div class="mt-16 pt-8 border-t border-border">
      <a
        href="/#work"
        class="font-mono text-xs text-fg-muted hover:text-accent transition-colors duration-150"
      >
        ← back to work
      </a>
    </div>
  </article>
</Base>
