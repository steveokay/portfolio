---
interface Props {
  slug: string;
  title: string;
  summary: string;
  tags: string[];
  improvement: string;
  date: Date;
}

const { slug, title, summary, tags, improvement, date } = Astro.props;

const dateStr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
---

<article class="group relative border border-border bg-surface p-6 hover:border-accent/30 transition-colors duration-200 h-full flex flex-col">
  <header class="mb-4">
    <div class="flex items-start justify-between gap-4 mb-2">
      <h3 class="font-mono text-sm text-accent leading-snug" transition:name={`cs-title-${slug}`}>
        <a
          href={`/work/${slug}`}
          class="hover:underline focus:outline-none focus-visible:underline"
        >
          {title}
        </a>
      </h3>
      <time class="font-mono text-[10px] text-fg-muted shrink-0 font-tabular pt-0.5">{dateStr}</time>
    </div>
    <p class="text-sm text-fg-secondary leading-relaxed">{summary}</p>
  </header>

  <div class="flex flex-wrap gap-1.5 mb-4 mt-auto">
    {tags.map((tag) => (
      <span class="font-mono text-[10px] text-fg-muted border border-border px-1.5 py-0.5">
        {tag}
      </span>
    ))}
  </div>

  <footer class="font-mono text-xs text-ok border-t border-border pt-3">
    ↑ {improvement}
  </footer>
</article>
