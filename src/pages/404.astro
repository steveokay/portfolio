---
import Base from '../layouts/Base.astro';
---

<Base title="404 — Not Found">
  <div class="min-h-[calc(100svh-2rem)] flex items-center justify-center px-4">
    <div class="max-w-sm w-full">
      <div class="font-mono text-[10px] text-fg-muted uppercase tracking-widest mb-6">
        error
      </div>

      <div class="font-mono text-sm bg-surface border border-border p-5 mb-8 space-y-1">
        <div class="text-fg-muted">exit status 1</div>
        <div class="text-error">404: route not found</div>
        <div class="mt-3">
          <span class="text-accent">❯</span>
          <span class="text-fg-secondary ml-2">no handler matched this path</span>
        </div>
      </div>

      <p class="text-sm text-fg-secondary mb-8">
        This route doesn't exist. Possibly a stale link.
      </p>

      <a
        href="/"
        class="font-mono text-sm text-accent hover:underline focus:outline-none focus-visible:underline"
      >
        ← return home
      </a>
    </div>
  </div>
</Base>
