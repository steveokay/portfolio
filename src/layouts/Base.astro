---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/instrument-serif/400.css';
import '@fontsource/instrument-serif/400-italic.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Steve Okoth — Cloud & Platform Engineer',
  description = 'Senior cloud / platform engineer. AWS-first infrastructure, IaC, reliability and cost ownership.',
} = Astro.props;

const canonicalURL = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : null;

const cfAnalyticsToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#faf8f4" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#131516" media="(prefers-color-scheme: dark)" />
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="/og.png" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <title>{title}</title>

    {cfAnalyticsToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token":"${cfAnalyticsToken}"}`}
      />
    )}
  </head>

  <body class="min-h-screen">
    <header class="no-print">
      <div class="mx-auto flex max-w-wide items-center justify-between gap-4 px-6 py-6 sm:px-10">
        <a
          href="/"
          class="font-mono text-meta uppercase tracking-widest text-muted hover:text-accent transition-colors duration-240"
        >
          steve okoth <span class="text-rule">/</span> ~/portfolio
        </a>
        <nav class="flex items-center gap-5 sm:gap-7" aria-label="Primary">
          <a
            href="/resume"
            class="font-mono text-meta uppercase tracking-widest text-muted hover:text-accent transition-colors duration-240"
          >
            resume
          </a>
          <a
            href="/#contact"
            class="font-mono text-meta uppercase tracking-widest text-muted hover:text-accent transition-colors duration-240"
          >
            contact &nbsp;→
          </a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="no-print mt-32 border-t border-rule">
      <div class="mx-auto flex max-w-wide flex-col items-start justify-between gap-3 px-6 py-8 font-mono text-meta text-muted sm:flex-row sm:items-center sm:px-10">
        <span>© {new Date().getFullYear()} Steve Okoth</span>
        <div class="flex items-center gap-6">
          <a href="https://github.com/steveokay" class="hover:text-accent transition-colors duration-240">
            gh/steveokay
          </a>
          <a href="mailto:stevieokoth@gmail.com" class="hover:text-accent transition-colors duration-240">
            email
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
