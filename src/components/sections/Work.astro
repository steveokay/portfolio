---
import { getCollection } from 'astro:content';
import RevealSection from '../islands/RevealSection';

const all = await getCollection('case-studies', ({ data }) => !data.draft);
const studies = all.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const [featured, ...rest] = studies;
---

<section id="work" class="px-4 py-24 border-t border-border">
  <RevealSection client:visible>
  <div class="mx-auto max-w-4xl">
    <h2 class="font-mono text-[10px] text-fg-muted uppercase tracking-widest mb-12">
      ~/work
    </h2>

    {studies.length === 0 ? (
      <p class="font-mono text-sm text-fg-muted">
        case studies in progress — set <code class="text-accent">draft: false</code> to publish
      </p>
    ) : (
      <>
        {/* Featured study — full-width editorial card */}
        {featured && (
          <a
            href={`/work/${featured.slug}`}
            class="group block border border-border bg-surface hover:border-accent/30 transition-colors duration-200 mb-px"
            aria-label={`Read: ${featured.data.title}`}
          >
            <div class="grid sm:grid-cols-[1fr_auto] gap-0">
              <div class="p-8 sm:p-10 border-r-0 sm:border-r border-border">
                <div class="font-mono text-[10px] text-fg-muted uppercase tracking-widest mb-4">
                  featured · {featured.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
                </div>
                <h3
                  class="font-mono text-lg sm:text-2xl text-accent leading-tight mb-4 group-hover:underline"
                  transition:name={`cs-title-${featured.slug}`}
                >
                  {featured.data.title}
                </h3>
                <p class="text-fg-secondary text-sm leading-relaxed max-w-xl mb-6">
                  {featured.data.summary}
                </p>
                <div class="flex flex-wrap gap-1.5 mb-6">
                  {featured.data.tags.map((tag: string) => (
                    <span class="font-mono text-[10px] text-fg-muted border border-border px-1.5 py-0.5">
                      {tag}
                    </span>
                  ))}
                </div>
                <span class="font-mono text-xs text-accent">
                  read postmortem →
                </span>
              </div>
              <div class="p-6 sm:p-8 flex flex-col justify-center gap-4 sm:min-w-[180px] border-t sm:border-t-0 border-border">
                {featured.data.metrics.improvement.split(' · ').map((item: string) => (
                  <div class="font-mono text-xs text-ok border-l-2 border-ok/40 pl-3">
                    ↑ {item}
                  </div>
                ))}
              </div>
            </div>
          </a>
        )}

        {/* Secondary studies — compact horizontal list */}
        {rest.length > 0 && (
          <div class="grid sm:grid-cols-2 gap-px bg-border mt-px">
            {rest.map((study) => (
              <div class="bg-bg">
                <a
                  href={`/work/${study.slug}`}
                  class="group flex flex-col h-full border border-border bg-surface hover:border-accent/30 transition-colors duration-200 p-6"
                  aria-label={`Read: ${study.data.title}`}
                >
                  <div class="font-mono text-[10px] text-fg-muted uppercase tracking-widest mb-3">
                    {study.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
                  </div>
                  <h3
                    class="font-mono text-sm text-accent leading-snug mb-2 group-hover:underline"
                    transition:name={`cs-title-${study.slug}`}
                  >
                    {study.data.title}
                  </h3>
                  <p class="text-xs text-fg-secondary leading-relaxed mb-4 flex-1">
                    {study.data.summary}
                  </p>
                  <div class="font-mono text-[11px] text-ok border-t border-border pt-3">
                    ↑ {study.data.metrics.improvement}
                  </div>
                </a>
              </div>
            ))}
          </div>
        )}
      </>
    )}
  </div>
  </RevealSection>
</section>
