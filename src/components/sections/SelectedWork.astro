---
import { getCollection } from 'astro:content';

const studies = (
  await getCollection('caseStudies', (e) => !e.data.draft)
).sort((a, b) => a.data.order - b.data.order);
---

{studies.length > 0 && (
  <section id="work" class="px-6 py-24 sm:px-10">
    <div class="mx-auto max-w-wide">
      <p class="text-eyebrow mb-3">selected work</p>
      <h2 class="text-section">Things I've shipped.</h2>
      <p class="mt-4 max-w-measure text-muted">
        Real systems. Real numbers. Each case study follows the same shape:
        problem, constraints, architecture, result, and what I'd do differently.
      </p>

      <ul class="mt-12 space-y-5" role="list">
        {studies.map((entry) => {
          const d = entry.data;
          return (
            <li>
              <a
                href={`/work/${entry.id}`}
                class="work-card group block border border-rule bg-bg p-6 sm:p-8 transition-colors duration-240 hover:border-accent"
              >
                <div class="flex items-start justify-between gap-6">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-baseline gap-4">
                      <span class="font-mono text-meta uppercase tracking-widest text-accent">
                        {d.eyebrow}
                      </span>
                      <span class="font-mono text-meta uppercase tracking-widest text-muted">
                        {d.year}
                      </span>
                    </div>

                    <h3 class="mt-3 font-serif text-2xl sm:text-3xl text-ink leading-tight">
                      {d.title}
                    </h3>

                    {d.framing && (
                      <p class="mt-2 font-mono text-meta uppercase tracking-widest text-muted">
                        {d.framing}
                      </p>
                    )}

                    <p class="mt-4 max-w-measure font-serif italic text-lg text-muted">
                      {d.oneLiner}
                    </p>

                    <ul class="mt-5 flex flex-wrap gap-2" role="list">
                      {d.stack.map((s) => (
                        <li class="border border-rule bg-surface/60 px-2 py-1 font-mono text-[10px] uppercase tracking-widest text-muted">
                          {s}
                        </li>
                      ))}
                    </ul>
                  </div>

                  <span
                    class="hidden sm:inline-block font-mono text-meta uppercase tracking-widest text-muted group-hover:text-accent transition-colors duration-240 shrink-0"
                    aria-hidden="true"
                  >
                    read&nbsp;→
                  </span>
                </div>

                <div class="mt-6 pt-6 border-t border-rule flex flex-wrap items-baseline justify-between gap-x-6 gap-y-2">
                  <span class="font-mono text-meta uppercase tracking-widest text-accent">
                    {d.metricHook}
                  </span>
                  <span class="sm:hidden font-mono text-meta uppercase tracking-widest text-accent">
                    read case study →
                  </span>
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </section>
)}
