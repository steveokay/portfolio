---
import RevealSection from '../islands/RevealSection';

// Real posts go here when published — section always visible.
const posts: Array<{
  title: string;
  url: string;
  date: string;
  venue: string;
}> = [
  // {
  //   title: 'Tracing Hot Paths in Go with pprof',
  //   url: 'https://...',
  //   date: '2025-03',
  //   venue: 'personal blog',
  // },
];

const drafts = [
  'tracing-hot-paths-in-go-with-pprof.md',
  'zero-downtime-migrations-at-50k-req-s.md',
  'what-six-percent-flaky-tests-actually-cost.md',
];
---

<section id="writing" class="px-4 py-24 border-t border-border">
  <RevealSection client:visible>
  <div class="mx-auto max-w-4xl">
    <h2 class="font-mono text-[10px] text-fg-muted uppercase tracking-widest mb-12">
      ~/writing
    </h2>

    {posts.length > 0 ? (
      <ul class="space-y-5 mb-12">
        {posts.map((post) => (
          <li class="flex items-baseline gap-4">
            <time class="font-mono text-xs text-fg-muted font-tabular shrink-0">{post.date}</time>
            <a
              href={post.url}
              class="text-sm text-fg hover:text-accent transition-colors duration-150"
              target={post.url.startsWith('http') ? '_blank' : undefined}
              rel={post.url.startsWith('http') ? 'noopener noreferrer' : undefined}
            >
              {post.title}
              <span class="font-mono text-xs text-fg-muted ml-2">— {post.venue}</span>
            </a>
          </li>
        ))}
      </ul>
    ) : null}

    {/* Draft listing — always visible, terminal ls aesthetic */}
    <div class="font-mono text-xs border border-border bg-surface p-5 max-w-2xl">
      <p class="text-fg-muted mb-4 text-[10px] uppercase tracking-widest">
        <span class="text-accent">❯</span> ls ./drafts/
      </p>
      <ul class="space-y-2.5 mb-5">
        {drafts.map((name) => (
          <li class="flex items-center justify-between gap-6">
            <span class="text-fg-secondary">{name}</span>
            <span class="text-fg-muted text-[10px] shrink-0">[draft]</span>
          </li>
        ))}
      </ul>
      <p class="text-fg-muted text-[10px] border-t border-border pt-4">
        # posts ship when they're ready
      </p>
    </div>
  </div>
  </RevealSection>
</section>
