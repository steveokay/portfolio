---
import { ViewTransitions } from 'astro:transitions';
import Cursor from '../components/islands/Cursor';
import '@fontsource/inter/400.css';
import '@fontsource/inter/600.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Steve Mokay — DevOps & Backend Engineer',
  description = 'Backend and infrastructure engineer. Real systems, real numbers.',
} = Astro.props;

const canonicalURL = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : null;

const cfAnalyticsToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og.png" />
    <meta property="og:image:width" content="1344" />
    <meta property="og:image:height" content="752" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="/og.png" />

    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <ViewTransitions />

    {cfAnalyticsToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token":"${cfAnalyticsToken}"}`}
      />
    )}

    <style is:global>
      #__loader {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: #0a0a0a;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        pointer-events: none;
      }
      #__loader-inner {
        font-family: 'JetBrains Mono', ui-monospace, Menlo, monospace;
        font-size: 0.7rem;
        line-height: 1.9;
        width: 100%;
        max-width: 360px;
      }
      .ll {
        opacity: 0;
        animation: ll-in 80ms ease-out forwards;
        color: #808080;
      }
      .ll:last-child { color: #ffb000; }
      @keyframes ll-in { to { opacity: 1; } }

      /* Hero entrance — content is rendered from the start (good for LCP);
         the loader covers it at z-index 9999 while it fades out.
         Classes used only as hooks if JS wants to add effects later. */
      .hero-caret { opacity: 0; }
      @media (prefers-reduced-motion: no-preference) {
        .hero-caret { transition: opacity 0.4s ease-out 0.3s; }
      }
      body.boot-done .hero-caret { opacity: 1; }
    </style>
  </head>

  <body class="min-h-screen bg-bg text-fg antialiased">
    <Cursor client:load />
    <!-- Boot loader — removed by inline script after animation or instantly if repeat visit -->
    <div id="__loader" aria-hidden="true">
      <div id="__loader-inner">
        <div class="ll" style="animation-delay:0ms"><span style="color:#ffb000">❯</span>&nbsp;./portfolio.sh --boot</div>
        <div class="ll" style="animation-delay:260ms">[&nbsp;&nbsp;0.041] runtime &nbsp;· go 1.23 · node 20</div>
        <div class="ll" style="animation-delay:500ms">[&nbsp;&nbsp;0.089] services · 3/3 healthy</div>
        <div class="ll" style="animation-delay:740ms">[&nbsp;&nbsp;0.132] metrics &nbsp;· nominal</div>
        <div class="ll" style="animation-delay:980ms">[&nbsp;&nbsp;0.158] ready.</div>
      </div>
    </div>
    <script>
      (function () {
        var el = document.getElementById('__loader');
        if (!el) return;
        function done() {
          el.remove();
          document.body.classList.add('boot-done');
          sessionStorage.setItem('sb', '1');
        }
        // Skip animation on repeat visits — hero appears immediately
        if (sessionStorage.getItem('sb')) { done(); return; }
        var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var hold = reduce ? 0 : 1550;
        setTimeout(function () {
          el.style.transition = 'opacity 0.3s ease-out';
          el.style.opacity = '0';
          setTimeout(done, 320);
        }, hold);
      })();
    </script>

    <!-- Fixed status bar — terminal chrome -->
    <div
      class="fixed top-0 left-0 right-0 z-50 h-8 border-b border-border bg-bg/95 backdrop-blur-sm"
      role="banner"
    >
      <div class="mx-auto flex h-full max-w-7xl items-center justify-between px-4 font-mono text-xs">
        <span class="flex items-center gap-1.5 text-accent">
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-ok animate-status-pulse" aria-hidden="true"></span>
          sys.online
        </span>

        <nav class="hidden sm:flex items-center gap-6 text-fg-secondary" aria-label="Primary">
          <a href="/#about" class="hover:text-accent transition-colors duration-150">~/about</a>
          <a href="/#work" class="hover:text-accent transition-colors duration-150">~/work</a>
          <a href="/#stack" class="hover:text-accent transition-colors duration-150">~/stack</a>
          <a href="/#lab" class="hover:text-accent transition-colors duration-150">~/lab</a>
          <a href="/#contact" class="hover:text-accent transition-colors duration-150">~/contact</a>
        </nav>

        <span class="text-fg-muted font-tabular hidden sm:block text-[10px]">
          built: {new Date().toISOString().slice(0, 10)}
        </span>
      </div>
    </div>

    <!-- Mobile bottom nav — terminal dock, hidden on sm+ where top nav is visible -->
    <nav
      class="sm:hidden fixed bottom-0 left-0 right-0 z-50 h-11 border-t border-border bg-bg/95 backdrop-blur-sm"
      aria-label="Mobile navigation"
    >
      <div class="grid grid-cols-5 h-full font-mono text-[10px]">
        {(['about', 'work', 'stack', 'lab', 'contact'] as const).map((id) => (
          <a
            href={`/#${id}`}
            class="flex items-center justify-center text-fg-secondary hover:text-accent hover:bg-surface transition-colors duration-150 border-r border-border last:border-r-0"
          >
            {id}
          </a>
        ))}
      </div>
    </nav>

    <main class="pt-8 pb-11 sm:pb-0">
      <slot />
    </main>

    <footer class="border-t border-border mt-32 py-8 mb-11 sm:mb-0">
      <div class="mx-auto max-w-7xl px-4 flex flex-col sm:flex-row items-center justify-between gap-4 font-mono text-xs text-fg-muted">
        <span>© {new Date().getFullYear()} Steve Mokay</span>
        <div class="flex items-center gap-6">
          <a
            href="https://github.com/mokaysteve"
            class="hover:text-accent transition-colors duration-150"
            target="_blank"
            rel="noopener noreferrer"
          >
            gh/mokaysteve
          </a>
          <a href="mailto:mokaysteve@gmail.com" class="hover:text-accent transition-colors duration-150">
            email
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
