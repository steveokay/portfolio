---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { certifications } from '../data/certifications';

/* -------------------------------------------------------------------------- */
/*  Resume content                                                            */
/*                                                                            */
/*  TODO(steve): replace the EXPERIENCE and EDUCATION arrays below with       */
/*  your real role history and degree. Everything else (certifications,       */
/*  selected projects) pulls from the same data sources the homepage uses.    */
/* -------------------------------------------------------------------------- */

const summary =
  'Cloud Infrastructure Engineer with ten years across software engineering, ' +
  'DevOps, and cloud platform work. AWS Certified. Track record cutting cloud ' +
  'spend, accelerating deployment cadence, and tightening incident response — ' +
  '$50K/month saved, deploy frequency from 5 to 100/day, MTTR from 5 hours to ' +
  '15 minutes. Comfortable across AWS, GCP, and Azure; Terraform, Ansible, ' +
  'Kubernetes, ArgoCD.';

interface Role {
  company: string;
  title: string;
  start: string;   // YYYY-MM
  end: string;     // YYYY-MM or 'present'
  location?: string;
  highlights: string[];
}

const experience: Role[] = [
  {
    company: 'Tala',
    title: 'Cloud Infrastructure Engineer II',
    start: '2025-03',
    end: 'present',
    highlights: [
      'Lead automation of infrastructure and platform services across AWS, GCP, and Azure with Terraform and Ansible.',
      'Architect new infra and platform solutions; deliver alongside development teams.',
      'Design and run continuous deployment on Kubernetes via ArgoCD and Jenkins.',
      'Application-performance alerting in Datadog and ElasticSearch — catch issues before they reach end users.',
      'On-call rotation; incident response and post-incident hardening.',
    ],
  },
  {
    company: 'Amazon Web Services',
    title: 'Cloud Support Engineer — Containers',
    start: '2024-05',
    end: '2025-03',
    highlights: [
      'Resolved customer cases for AWS container services across phone, email, and live chat.',
      'Advanced troubleshooting to dive into root cause on complex container / orchestration issues.',
      'Partnered with development teams on complex escalations and contact-deflection initiatives.',
      'Wrote internal tools / scripts to streamline team workflows; contributed to process and policy compliance.',
    ],
  },
  {
    company: 'Cellulant Kenya',
    title: 'Senior DevOps Engineer',
    start: '2021-10',
    end: '2024-05',
    highlights: [
      'Lifted deployment frequency from 5/day to ~100/day by automating the release pipeline in GitLab CI.',
      'Cut lead time for changes from 2 days to 10 minutes by automating the change-approval flow.',
      'Reduced change failure rate by 25% with rigorous unit / integration / performance gates before prod.',
      'Cut MTTR from 5 hours to under 15 minutes — service backups, proactive monitoring, automated failover.',
      'Reduced monthly cloud spend from $175K to $125K via right-sizing, reserved instances, and Fargate for spiky workloads.',
      'Built an internal developer platform on Backstage — bootstrapping scripts, infra catalog, golden paths.',
      'Automated all infrastructure provisioning in Terraform + Ansible.',
    ],
  },
  {
    company: 'Finserve Africa',
    title: 'Product Support Technical Lead',
    start: '2021-05',
    end: '2021-10',
    highlights: [
      'Improved system uptime by 25% via better monitoring and proactive incident response.',
      'Led the go-live of Jenga API and Jenga Payment Gateway integrations.',
      'Streamlined support process — cut issue resolution time by 40%.',
      'Enforced rigorous pre-release testing across product surfaces.',
    ],
  },
  {
    company: 'NCBA Bank Kenya',
    title: 'Integration Specialist',
    start: '2020-09',
    end: '2021-04',
    highlights: [
      'Hit 98% SLA adherence across service-lifecycle management.',
      'Cut integration errors by 30% and improved API response times by 25%.',
      'Integrated four key systems; cross-functional response time up 35%.',
      'Hardened security posture — 15% drop in security-related incidents.',
    ],
  },
  {
    company: 'Cellulant Kenya',
    title: 'HUB SIP Engineer',
    start: '2018-12',
    end: '2020-09',
    highlights: [
      'Ran disaster-recovery drills; validated system resilience.',
      'Cut application incidents by 20% via proactive monitoring.',
      'New deployment strategy reduced system downtime by 15%.',
      'Documentation overhaul — 25% drop in time-to-troubleshoot.',
    ],
  },
  {
    company: 'Sanergy',
    title: 'Software Engineer',
    start: '2018-03',
    end: '2018-11',
    highlights: [
      'Streamlined the software release process — 20% reduction in errors.',
      'Code-optimization measures improved system performance by 15%.',
      'Led a team on a new module — 30% lift in user satisfaction.',
    ],
  },
  {
    company: 'Stanbic Bank Kenya',
    title: 'Software Engineer',
    start: '2016-08',
    end: '2017-11',
    highlights: [
      'Contributed to the Payments and Collections initiative that materially grew the bank’s liabilities within the year.',
      'Built the Receipt Referencing System — direct integrations with schools and businesses; drove deposit growth.',
      'Integrated the bank’s tea-trading system to Equity Bank.',
      'Customer risk-rating tool to score risk on loan and account products.',
      'Self-service insurance-renewal flow for staff.',
    ],
  },
];

interface Education {
  school: string;
  degree: string;
  year: string;
}

const education: Education[] = [
  // {
  //   school: 'University of …',
  //   degree: 'BSc Computer Science',
  //   year: '2017',
  // },
];

/* Stack — categorized; alphabetical within each (matches CLAUDE.md convention) */
const stack = {
  cloud: ['AWS (EKS, S3, EC2, VPC, IAM, NLB, ALB)', 'Azure', 'GCP'],
  iac: ['Ansible', 'Pulumi', 'Terraform'],
  containers: ['ArgoCD', 'Docker', 'Docker Swarm', 'Helm', 'Kubernetes'],
  observability: ['Datadog', 'ElasticSearch', 'Grafana', 'New Relic', 'Prometheus'],
  cicd: ['ArgoCD', 'Git', 'GitHub Actions', 'GitLab CI/CD', 'Jenkins'],
  languages: ['Bash', 'Core Java', 'Go', 'PHP', 'Python', 'Spring Boot'],
  data: ['MySQL', 'Oracle', 'PostgreSQL', 'RabbitMQ', 'Redis'],
};

const studies = (
  await getCollection('caseStudies', (e) => !e.data.draft)
).sort((a, b) => a.data.order - b.data.order);

function formatDate(iso: string): string {
  return iso.slice(0, 7);
}
function dateRange(start: string, end: string): string {
  return `${formatDate(start)} — ${end === 'present' ? 'present' : formatDate(end)}`;
}
function statusFor(c: { expires?: string }): 'current' | 'expired' {
  if (!c.expires) return 'current';
  return new Date(c.expires) < new Date() ? 'expired' : 'current';
}
---

<Base
  title="Resume — Steve Okoth"
  description="Cloud & Platform Engineer · Senior · AWS-first"
>
  <!-- Hint banner — hidden in print -->
  <div class="no-print mx-auto max-w-measure px-6 sm:px-10 pt-8">
    <p class="border border-rule bg-surface/40 px-4 py-3 font-mono text-meta uppercase tracking-widest text-muted">
      print &nbsp;·&nbsp; <kbd class="font-mono">Ctrl + P</kbd>
      &nbsp;or&nbsp; <kbd class="font-mono">Cmd + P</kbd>
      &nbsp;·&nbsp; save as pdf
    </p>
  </div>

  <article class="resume mx-auto max-w-measure px-6 sm:px-10 py-10">
    <!-- HEADER ============================================================ -->
    <header class="resume-header">
      <h1 class="resume-name">Steve Okoth</h1>
      <p class="resume-role">Cloud &amp; Platform Engineer</p>

      <ul class="resume-contact" role="list">
        <li><a href="mailto:stevieokoth@gmail.com">stevieokoth@gmail.com</a></li>
        <li><a href="tel:+254714362027">+254 714 362 027</a></li>
        <li><a href="https://github.com/steveokay">github.com/steveokay</a></li>
        <li>portfolio.mokaysteve.workers.dev</li>
        <!-- TODO(steve): drop in your LinkedIn URL when ready -->
        <!-- <li><a href="https://linkedin.com/in/steveokoth">linkedin.com/in/steveokoth</a></li> -->
      </ul>
    </header>

    <!-- SUMMARY =========================================================== -->
    <section class="resume-section">
      <h2 class="resume-section-title">summary</h2>
      <p class="resume-summary">{summary}</p>
    </section>

    <!-- EXPERIENCE ======================================================== -->
    <section class="resume-section">
      <h2 class="resume-section-title">experience</h2>
      {experience.length === 0 ? (
        <p class="resume-todo">
          [&nbsp;todo:&nbsp; populate <code>experience</code> in <code>src/pages/resume.astro</code> with your real role history. Each role takes: company, title, start (YYYY-MM), end (YYYY-MM or 'present'), location, and 2–4 highlight bullets.&nbsp;]
        </p>
      ) : (
        <ul class="resume-roles" role="list">
          {experience.map((r) => (
            <li class="resume-role-entry">
              <div class="resume-role-head">
                <span class="resume-role-title">{r.title}</span>
                <span class="resume-role-dates">{dateRange(r.start, r.end)}</span>
              </div>
              <p class="resume-role-company">
                {r.company}{r.location ? ` · ${r.location}` : ''}
              </p>
              <ul class="resume-role-highlights" role="list">
                {r.highlights.map((h) => <li>{h}</li>)}
              </ul>
            </li>
          ))}
        </ul>
      )}
    </section>

    <!-- SELECTED PROJECTS ================================================= -->
    {studies.length > 0 && (
      <section class="resume-section">
        <h2 class="resume-section-title">selected projects</h2>
        <ul class="resume-projects" role="list">
          {studies.map((entry) => {
            const d = entry.data;
            return (
              <li class="resume-project">
                <div class="resume-project-head">
                  <span class="resume-project-title">{d.title}</span>
                  <span class="resume-project-year">{d.year}</span>
                </div>
                <p class="resume-project-oneliner">{d.oneLiner}</p>
                <p class="resume-project-meta">
                  {d.stack.join(' · ')}
                </p>
                <p class="resume-project-hook">{d.metricHook}</p>
                {d.repo && (
                  <p class="resume-project-link">
                    <a href={d.repo}>{d.repo.replace(/^https?:\/\//, '')}</a>
                  </p>
                )}
              </li>
            );
          })}
        </ul>
      </section>
    )}

    <!-- CERTIFICATIONS ==================================================== -->
    {certifications.length > 0 && (
      <section class="resume-section">
        <h2 class="resume-section-title">cloud certifications</h2>
        <ul class="resume-certs" role="list">
          {certifications.map((c) => {
            const status = statusFor(c);
            return (
              <li class="resume-cert">
                <span class="resume-cert-title">{c.title}</span>
                <span class="resume-cert-dates">
                  earned {formatDate(c.earned)}
                  {c.expires && ` · ${status === 'current' ? 'expires' : 'expired'} ${formatDate(c.expires)}`}
                </span>
              </li>
            );
          })}
        </ul>
      </section>
    )}

    <!-- STACK ============================================================= -->
    <section class="resume-section">
      <h2 class="resume-section-title">stack</h2>
      <dl class="resume-stack">
        <dt>cloud</dt><dd>{stack.cloud.join(' · ')}</dd>
        <dt>iac</dt><dd>{stack.iac.join(' · ')}</dd>
        <dt>containers</dt><dd>{stack.containers.join(' · ')}</dd>
        <dt>observability</dt><dd>{stack.observability.join(' · ')}</dd>
        <dt>ci / cd</dt><dd>{stack.cicd.join(' · ')}</dd>
        <dt>languages</dt><dd>{stack.languages.join(' · ')}</dd>
        <dt>data</dt><dd>{stack.data.join(' · ')}</dd>
      </dl>
    </section>

    <!-- EDUCATION ========================================================= -->
    <section class="resume-section">
      <h2 class="resume-section-title">education</h2>
      {education.length === 0 ? (
        <p class="resume-todo">
          [&nbsp;todo:&nbsp; populate <code>education</code> in <code>src/pages/resume.astro</code>.&nbsp;]
        </p>
      ) : (
        <ul class="resume-education" role="list">
          {education.map((e) => (
            <li class="resume-edu-entry">
              <span class="resume-edu-degree">{e.degree}</span>
              <span class="resume-edu-school">{e.school}</span>
              <span class="resume-edu-year">{e.year}</span>
            </li>
          ))}
        </ul>
      )}
    </section>
  </article>
</Base>

<style>
  /* ============================================================= */
  /*  Screen styles                                                 */
  /* ============================================================= */

  .resume {
    font-family: 'Inter', ui-sans-serif, system-ui, sans-serif;
    color: var(--ink);
    line-height: 1.5;
  }

  .resume-header {
    margin-bottom: 1.5rem;
  }

  .resume-name {
    font-family: 'Instrument Serif', ui-serif, Georgia, serif;
    font-size: clamp(2rem, 4.5vw, 2.75rem);
    font-weight: 400;
    color: var(--ink);
    letter-spacing: -0.01em;
    line-height: 1;
    margin: 0;
  }

  .resume-role {
    font-family: 'Instrument Serif', ui-serif, Georgia, serif;
    font-size: 1.25rem;
    font-style: italic;
    color: var(--muted);
    margin: 0.3rem 0 0.9rem;
  }

  .resume-contact {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.78rem;
    color: var(--muted);
  }
  .resume-contact a {
    color: var(--accent);
    text-decoration: none;
  }
  .resume-contact a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .resume-section {
    margin-top: 1.6rem;
    padding-top: 1.1rem;
    border-top: 1px solid var(--rule);
  }

  .resume-section-title {
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--muted);
    margin: 0 0 0.85rem;
    font-weight: 500;
  }

  .resume-summary {
    margin: 0;
    color: var(--ink);
  }

  /* Generic TODO callout (experience / education) */
  .resume-todo {
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.78rem;
    color: var(--muted);
    border-left: 2px solid var(--warn);
    padding-left: 0.75rem;
    margin: 0;
    line-height: 1.55;
  }
  .resume-todo code {
    color: var(--ink);
    background: var(--surface);
    padding: 0 0.25rem;
    border-radius: 2px;
  }

  /* Experience entries */
  .resume-roles { list-style: none; padding: 0; margin: 0; }
  .resume-role-entry { margin-bottom: 1.1rem; }
  .resume-role-entry:last-child { margin-bottom: 0; }
  .resume-role-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }
  .resume-role-title {
    font-weight: 600;
    color: var(--ink);
  }
  .resume-role-dates {
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.76rem;
    color: var(--muted);
    white-space: nowrap;
  }
  .resume-role-company {
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.78rem;
    color: var(--muted);
    margin: 0.15rem 0 0.5rem;
  }
  .resume-role-highlights {
    list-style: none;
    padding: 0;
    margin: 0.3rem 0 0;
  }
  .resume-role-highlights li {
    position: relative;
    padding-left: 1rem;
    margin-bottom: 0.25rem;
    line-height: 1.55;
  }
  .resume-role-highlights li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  /* Projects */
  .resume-projects { list-style: none; padding: 0; margin: 0; }
  .resume-project { margin-bottom: 1rem; }
  .resume-project:last-child { margin-bottom: 0; }
  .resume-project-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }
  .resume-project-title {
    font-weight: 600;
    color: var(--ink);
  }
  .resume-project-year {
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.76rem;
    color: var(--muted);
    white-space: nowrap;
  }
  .resume-project-oneliner {
    font-style: italic;
    color: var(--muted);
    margin: 0.2rem 0 0.4rem;
  }
  .resume-project-meta,
  .resume-project-link,
  .resume-project-hook {
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.76rem;
    color: var(--muted);
    margin: 0.1rem 0;
  }
  .resume-project-hook { color: var(--accent); }
  .resume-project-link a {
    color: var(--accent);
    text-decoration: none;
  }
  .resume-project-link a:hover { text-decoration: underline; }

  /* Certifications */
  .resume-certs { list-style: none; padding: 0; margin: 0; }
  .resume-cert {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.3rem 0;
    border-bottom: 1px dotted var(--rule);
  }
  .resume-cert:last-child { border-bottom: 0; }
  .resume-cert-title { color: var(--ink); }
  .resume-cert-dates {
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.76rem;
    color: var(--muted);
    white-space: nowrap;
  }

  /* Stack */
  .resume-stack {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 0.5rem 1.2rem;
    margin: 0;
  }
  .resume-stack dt {
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
  }
  .resume-stack dd {
    margin: 0;
    color: var(--ink);
  }

  /* Education */
  .resume-education { list-style: none; padding: 0; margin: 0; }
  .resume-edu-entry {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.3rem 0;
  }
  .resume-edu-degree { font-weight: 600; color: var(--ink); }
  .resume-edu-school {
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.78rem;
    color: var(--muted);
    flex: 1;
  }
  .resume-edu-year {
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.76rem;
    color: var(--muted);
    white-space: nowrap;
  }

  /* ============================================================= */
  /*  Print styles — single-page letter / A4, generous margins      */
  /* ============================================================= */

  @media print {
    @page {
      size: letter;
      margin: 0.6in 0.7in;
    }

    .resume {
      padding: 0;
      max-width: 100%;
      font-size: 10pt;
      line-height: 1.42;
    }

    .resume-name { font-size: 22pt; }
    .resume-role { font-size: 13pt; margin-top: 0.15rem; margin-bottom: 0.5rem; }
    .resume-contact { font-size: 9pt; gap: 0.3rem 0.8rem; }

    .resume-section { margin-top: 0.9rem; padding-top: 0.55rem; }
    .resume-section-title { font-size: 8pt; margin-bottom: 0.5rem; }

    .resume-summary,
    .resume-role-highlights li,
    .resume-stack dd,
    .resume-cert-title,
    .resume-edu-degree { font-size: 10pt; }

    .resume-role-dates,
    .resume-role-company,
    .resume-project-meta,
    .resume-project-link,
    .resume-project-hook,
    .resume-cert-dates,
    .resume-stack dt,
    .resume-edu-school,
    .resume-edu-year { font-size: 9pt; }

    .resume-role-entry,
    .resume-project,
    .resume-cert,
    .resume-edu-entry {
      page-break-inside: avoid;
    }

    /* Hide the print hint */
    .no-print { display: none !important; }

    /* Hide screen-only chrome from Base.astro (header / footer already
       handled by global.css print stylesheet, but reinforce) */
    body > header,
    body > footer { display: none !important; }
  }
</style>
