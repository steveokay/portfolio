---
import RevealSection from '../islands/RevealSection';
import CountUp from '../islands/CountUp';

const impact = [
  { metric: '68%', label: 'p99 latency reduction on a 50k req/s API' },
  { metric: '40%', label: 'infrastructure cost reduction via k8s migration' },
  { metric: '81%', label: 'CI build time reduction — 48 min to 9 min' },
  { metric: '12 svc', label: 'production services migrated with zero downtime' },
] as const;
---

<section id="about" class="px-4 py-24 border-t border-border">
  <RevealSection client:visible>
  <div class="mx-auto max-w-4xl">
    <h2 class="font-mono text-[10px] text-fg-muted uppercase tracking-widest mb-12">
      ~/about
    </h2>

    <div class="grid md:grid-cols-2 gap-16 items-start">
      <div>
        <p class="text-lg leading-relaxed text-fg mb-6">
          I build the systems that keep products fast and reliable under load.
          Six years across fintech, SaaS, and infrastructure tooling.
        </p>
        <p class="text-fg-secondary leading-relaxed mb-6">
          Specialties: Go services under high concurrency, Kubernetes cluster
          operations, Postgres at scale, and observable CI/CD pipelines. I
          write Terraform for infrastructure I'd trust to run unattended.
        </p>
        <p class="text-fg-secondary leading-relaxed">
          Open to senior or staff backend / platform engineering roles.
          Remote or NYC / London.
        </p>
      </div>

      <div class="space-y-6">
        {impact.map(({ metric, label }) => (
          <CountUp value={metric} label={label} client:visible />
        ))}
      </div>
    </div>
  </div>
  </RevealSection>
</section>
